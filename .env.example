GAMEMIND_ENV=local
GAMEMIND_LOG_LEVEL=INFO
GAMEMIND_OPENAI_API_KEY=
GAMEMIND_OPENAI_CHAT_MODEL=gpt-4o-mini
GAMEMIND_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GAMEMIND_USE_LOCAL_EMBEDDINGS=true
GAMEMIND_USE_LOCAL_RANKER=true
GAMEMIND_DATASET_PATH=data/sample_games.jsonl
GAMEMIND_CHROMA_PATH=.chroma
GAMEMIND_CHROMA_COLLECTION=games
